# ---- Public (exposed to browser) ----
NEXT_PUBLIC_SITE_URL=https://dongying-casting.com
# Cloudflare Turnstile (anti-bot). Leave blank to disable in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# China search engines — fill once registered (all optional)
NEXT_PUBLIC_BAIDU_VERIFICATION=
NEXT_PUBLIC_SOGOU_VERIFICATION=
NEXT_PUBLIC_360_VERIFICATION=
# Baidu Tongji (百度统计) site id from the hm.js?<id> snippet
NEXT_PUBLIC_BAIDU_TONGJI=

# ---- Server-only secrets (never commit real values) ----
TURNSTILE_SECRET_KEY=
# Contact form email delivery (Resend). Inquiries are sent to SITE.email (cindy@dywanlong.com).
RESEND_API_KEY=
# Verified sender on your Resend domain, e.g. "Dongying Casting <noreply@dywanlong.com>"
CONTACT_FROM=
# Cloudflare R2 for scanned attachment storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
