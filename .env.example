# ---- Public (exposed to browser) ----
NEXT_PUBLIC_SITE_URL=https://dongying-casting.com
# Cloudflare Turnstile (anti-bot). Leave blank to disable in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# China search engines — fill once registered (all optional)
NEXT_PUBLIC_BAIDU_VERIFICATION=
NEXT_PUBLIC_SOGOU_VERIFICATION=
NEXT_PUBLIC_360_VERIFICATION=
# Baidu Tongji (百度统计) site id from the hm.js?<id> snippet
NEXT_PUBLIC_BAIDU_TONGJI=

# ---- Server-only secrets (never commit real values) ----
TURNSTILE_SECRET_KEY=
# Contact/quote form email delivery via SMTP (Hostinger Business Email).
# Inquiries are sent to SITE.contactTo (quote@dongying-casting.com).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=quote@dongying-casting.com
SMTP_PASS=
# Sender shown on the email (use the same mailbox/domain for best deliverability)
CONTACT_FROM=Dongying Casting <quote@dongying-casting.com>
