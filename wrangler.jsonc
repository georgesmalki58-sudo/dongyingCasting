{
  // Cloudflare deployment via @opennextjs/cloudflare (Workers) — see README.
  "name": "dongying-casting",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": { "directory": ".open-next/assets", "binding": "ASSETS" }
  // Add bindings here when wired:
  // "kv_namespaces": [{ "binding": "RATE_LIMIT", "id": "<kv-id>" }],
  // "r2_buckets": [{ "binding": "UPLOADS", "bucket_name": "dongying-uploads" }]
}
